DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
TEXT_MODEL_PROVIDER=deepseek

# "none" disables external vision/file models. Uploaded source files are parsed locally by default.
VISION_MODEL_PROVIDER=none
FILE_MODEL_PROVIDER=none

LARGE_TEXT_LIMIT=30000
PORT=4120
SQLITE_PATH=./data/interchange.sqlite
UPLOAD_LIMIT_MB=25
MARKITDOWN_COMMAND=markitdown
MARKITDOWN_TIMEOUT_MS=15000
